@startuml kg_activity_register
' ============================================================
' 活动图 — 注册与验证码流程
' 标准 UML：起始/终止、判断节点、循环(倒计时)、超时处理
' ============================================================
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11
skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 11
}
skinparam diamondBackgroundColor #FFF9C4
skinparam diamondBorderColor #F57F17
skinparam startColor #4CAF50
skinparam endColor #F44336

title 注册与验证码流程 — 活动图

|学生|
start
:进入注册页面;
:填写信息\n(用户名、邮箱、密码);

:输入邮箱;

|系统|
if (60 秒内已发送?) then (是)
    |学生|
    :等待倒计时;
    note right
        前端禁用按钮
        显示剩余秒数
    end note
else (否)
    |系统|
    :生成 6 位随机验证码;
    :存入 sys_email_code\n(email, code, type, expire_time);
    note right
        expire_time = now() + 5分钟
    end note
    :输出验证码\n(console/邮件);
endif

|学生|
:输入验证码;
:提交注册表单;

|系统|
if (验证码正确?) then (否)
    |学生|
    :提示"验证码错误";
    :重新输入验证码;
    detach
endif

|系统|
if (5 分钟内?) then (否)
    |学生|
    :提示"验证码已过期";
    :重新获取验证码;
    detach
endif

|系统|
if (账号唯一?) then (否)
    |学生|
    :提示"账号已存在";
    :修改用户名;
    detach
endif

|系统|
:MD5 加密密码;
:INSERT INTO sys_user;
:标记验证码已使用\n(UPDATE is_used = 1);

|学生|
:提示"注册成功";
:跳转登录页;
stop

@enduml
