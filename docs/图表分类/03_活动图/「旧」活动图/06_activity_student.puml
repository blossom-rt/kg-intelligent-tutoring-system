@startuml kg_activity_student
' ============================================================
' 活动图 — 学生完整学习流程（v2）
' ============================================================
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11
skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 11
}
skinparam diamondBackgroundColor #FFF9C4
skinparam diamondBorderColor #F57F17
skinparam startColor #4CAF50
skinparam endColor #F44336

title 学生完整学习流程 — 活动图 (v2)

start

:访问系统;

if (已注册?) then (否)
    :填写注册信息;
    :获取邮箱验证码;
    :提交注册;
    :注册成功;
endif

:登录系统;

if (首次登录?) then (是)
    :进入新手引导;
else (否)
    :进入学情看板;
    if (有进行中的路径?) then (是)
        :快捷续学;
    endif
endif

:浏览 3D 知识图谱\n(Three.js 力导向图);
:选择目标知识点;

:生成学习路径;
note right
    拓扑排序计算前置依赖链
    创建 study_path + path_detail
end note

:🎉 撒花 (50粒子);

while (还有未完成节点?) is (是)
    :进入知识点学习页\n(NodeStudy);

    :学习知识点内容;

    if (有视频/学习资源?) then (是)
        :浏览学习资源\n(learning_resource);
        note right
            视频、文档、
            外部链接等
        end note
    endif

    if (需要 AI 帮助?) then (是)
        :AI 划重点;
        note right
            调用 DeepSeek
            提取知识点核心
        end note
        :AI 答疑;
        note right
            学生提问
            AI 上下文回答
        end note
    endif

    if (想收藏?) then (是)
        :收藏知识点\n(user_favorite);
    endif

    :完成配套练习;

    :提交答案;

    if (答对?) then (是)
        :🎉 撒花 (80粒子);
        :自动标记已掌握;
    else (否)
        :记录错题\n(wrong_question);
        :AI 讲解错题;
    endif

    if (正确率 ≥ 80%?) then (是)
        :标记节点已掌握\n(mastery_level = 2);
        :解锁下一节点;
    else (否)
        :标记学习中\n(mastery_level = 1);
        :继续刷题;
    endif
endwhile (否)

:🎉 大烟花庆祝\n(2.5s 持续喷射 + 150粒子);
:路径完成！;

:参加章节测评;
note right
    限时答题
    自动判分
end note

if (测评通过?) then (是)
    :生成 AI 诊断报告;
    :查看报告;
    stop
else (否)
    :错题自动收录;

    :进入错题本;
    :查看错题讲解;
    :错题重做;

    if (重做答对?) then (是)
        :🎉 撒花 (80粒子);
        :标记已掌握;
        :从错题本移除;
    else (否)
        :保留在错题本;
    endif

    :再次测评;
    detach
endif

@enduml
