digraph 学生活动图_4_3_紧凑版 {
    size="10,7.5!";
    ratio="fill";
    rankdir=TB;
    splines=true;
    newrank=true;
    fontname="PingFang SC,Microsoft YaHei,sans-serif";
    fontsize=16;
    label="学生完整学习流程 — 活动图 (4:3 紧凑放大版)";
    labelloc=t;
    dpi=200;

    nodesep=0.25;
    ranksep=0.25;

    start [shape=point, width=0.25, fillcolor=black];
    stop_node [shape=doublecircle, style=filled, fillcolor=black, width=0.22, label=""];
    detach_node [shape=circle, style=filled, fillcolor=black, width=0.15, label=""];

    node [shape=box, style="rounded, filled", fillcolor="#fbfbfb", color="#444444", fontname="PingFang SC,Microsoft YaHei,sans-serif", fontsize=10, height=0.4, width=1.3, penwidth=1.2];

    subgraph cluster_0 {
        label="一、系统访问与路径规划";
        fontname="PingFang SC,Microsoft YaHei,sans-serif";
        fontsize=11;
        style="dashed, filled";
        fillcolor="#f0f4f8";
        color="#b0c4de";

        a1 [label="访问系统"];
        a2 [label="注册"];
        a3 [label="登录系统"];
        a4 [label="新手引导"];
        a5 [label="学情看板"];
        a6 [label="快捷续学"];
        a7 [label="浏览3D知识图谱"];
        a8 [label="选目标知识点"];
        a9 [label="生成学习路径"];

        node [shape=diamond, style=filled, fillcolor="#ffffff", color="#444444", fontname="PingFang SC,Microsoft YaHei,sans-serif", fontsize=9.5, height=0.45, width=1.0];
        d1 [label="已注册?"];
        d2 [label="首次登录?"];
        d3 [label="有进行\n中路径?"];
    }

    subgraph cluster_1 {
        label="二、知识点精修与闭环练习";
        fontname="PingFang SC,Microsoft YaHei,sans-serif";
        fontsize=11;
        style="dashed, filled";
        fillcolor="#f5f5f5";
        color="#d3d3d3";

        node [shape=box, style="rounded, filled", fillcolor="#fbfbfb", color="#444444", fontsize=10, height=0.4, width=1.3];
        a10 [label="进入知识点学习"];
        a11 [label="学习内容"];
        a12 [label="浏览学习资源"];
        a13 [label="AI划重点"];
        a14 [label="AI答疑"];
        a15 [label="收藏知识点"];
        a16 [label="做练习"];
        a17 [label="提交答案"];
        a18 [label="标记已掌握"];
        a19 [label="记录错题"];
        a20 [label="AI讲解"];
        a21 [label="标记已掌握\n解锁下一个"];
        a22 [label="标记学习中\n继续刷题"];

        node [shape=diamond, style=filled, fillcolor="#ffffff", color="#444444", fontsize=9.5, height=0.45, width=1.0];
        d4 [label="还有未\n完成?"];
        d5 [label="有学习\n资源?"];
        d6 [label="需AI\n帮助?"];
        d7 [label="收藏?"];
        d8 [label="答对?"];
        d9 [label="正确率\n>=80%?"];
    }

    subgraph cluster_2 {
        label="三、章节学情测评与错题强化";
        fontname="PingFang SC,Microsoft YaHei,sans-serif";
        fontsize=11;
        style="dashed, filled";
        fillcolor="#f4f9f4";
        color="#bcdeb0";

        node [shape=box, style="rounded, filled", fillcolor="#fbfbfb", color="#444444", fontsize=10, height=0.4, width=1.3];
        a23 [label="路径完成！"];
        a24 [label="参加章节测评"];
        a25 [label="AI诊断报告"];
        a26 [label="查看报告"];
        a27 [label="错题收录"];
        a28 [label="错题本"];
        a29 [label="看讲解"];
        a30 [label="错题重做"];
        a31 [label="标记掌握\n移除错题本"];
        a32 [label="保留错题本"];
        a33 [label="再次测评"];

        node [shape=diamond, style=filled, fillcolor="#ffffff", color="#444444", fontsize=9.5, height=0.45, width=1.0];
        d10 [label="测评\n通过?"];
        d11 [label="重做\n答对?"];
    }

    { rank=same; d1; a2; }
    { rank=same; d2; a4; a5; }
    { rank=same; d3; a6; }
    { rank=same; d5; a12; }
    { rank=same; d6; a13; }
    { rank=same; d7; a15; }
    { rank=same; d8; a18; a19; }
    { rank=same; d11; a31; a32; }

    edge [fontname="PingFang SC,Microsoft YaHei,sans-serif", fontsize=8.5, color="#555555", penwidth=1.1];

    start -> a1;
    a1 -> d1;
    d1 -> a2 [xlabel="否"];
    a2 -> a3;
    d1 -> a3 [xlabel="是"];
    a3 -> d2;
    d2 -> a4 [xlabel="是"];
    a4 -> a7;
    d2 -> a5 [xlabel="否"];
    a5 -> d3;
    d3 -> a6 [xlabel="是"];
    a6 -> a7;
    d3 -> a7 [xlabel="否"];
    a7 -> a8;
    a8 -> a9;

    a9 -> d4;

    d4 -> a10 [xlabel="是"];
    a10 -> a11;
    a11 -> d5;
    d5 -> a12 [xlabel="是"];
    d5 -> d6 [xlabel="否"];
    a12 -> d6;
    d6 -> a13 [xlabel="是"];
    a13 -> a14;
    a14 -> d7;
    d6 -> d7 [xlabel="否"];
    d7 -> a15 [xlabel="是"];
    a15 -> a16;
    d7 -> a16 [xlabel="否"];
    a16 -> a17;
    a17 -> d8;

    d8 -> a18 [xlabel="是"];
    a18 -> d9;
    d8 -> a19 [xlabel="否"];
    a19 -> a20;
    a20 -> d9;
    d9 -> a21 [xlabel="是"];
    a21 -> d4;
    d9 -> a22 [xlabel="否"];
    a22 -> d4;

    d4 -> a23 [xlabel="否"];
    a23 -> a24;
    a24 -> d10;
    d10 -> a25 [xlabel="是"];
    a25 -> a26;
    a26 -> stop_node;

    d10 -> a27 [xlabel="否"];
    a27 -> a28;
    a28 -> a29;
    a29 -> a30;
    a30 -> d11;
    d11 -> a31 [xlabel="是"];
    a31 -> a33;
    d11 -> a32 [xlabel="否"];
    a32 -> a33;
    a33 -> detach_node;
}
