@startuml kg_activity_admin
' ============================================================
' 活动图 — 管理员工作流程（新增）
' ============================================================
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11
skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 11
}
skinparam diamondBackgroundColor #FFF9C4
skinparam diamondBorderColor #F57F17
skinparam startColor #4CAF50
skinparam endColor #F44336
skinparam partitionBorderColor #333333
skinparam partitionBackgroundColor #FAFAFA

title 管理员工作流程 — 活动图 (新增)

|管理员|
start
:登录系统;
:进入管理后台;

|管理员|
if (操作类型?) then (用户管理)

    :查看用户列表;
    note right
        sys_user 全字段
        含角色关联
    end note

    :创建/编辑/禁用/删除用户;
    note right
        分配角色(role_id)
        设置密码(MD5)
        管理状态(status)
    end note

elseif (角色管理?) then (是)

    :管理系统角色\n(sys_role);
    note right
        role_code: admin/teacher/student
        role_name: 管理员/教师/学生
        description
    end note

    :配置角色权限;

elseif (课程管理?) then (是)

    :审核/管理课程\n(course);
    note right
        subject, course_name
        description, teacher_id
    end note

elseif (公告管理?) then (是)

    :发布系统公告\n(sys_notice);
    note right
        title, content
        target_role(推送对象)
        create_time
    end note

    if (紧急公告?) then (是)
        :全站推送;
    else (否)
        :按角色推送;
    endif

else (操作审计)

    :查看操作日志\n(sys_oper_log);
    note right
        user_id, module
        operation, ip
        create_time
    end note

    :查看 AI 调用日志\n(ai_call_log);
    note right
        user_id, scene
        prompt, result
        call_duration, status
    end note

    if (异常操作?) then (是)
        :标记/告警;
    else (否)
        :归档日志;
    endif

endif

|管理员|
stop

@enduml
