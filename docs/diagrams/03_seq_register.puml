@startuml kg_seq_register
' ============================================================
' 顺序图 — 注册流程
' 标准 UML：生命线、激活框、alt/else、note
' ============================================================
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 11
skinparam sequenceMessageAlign center

title 学生注册 — 顺序图

actor "学生" as S
participant "Vue 前端" as F
participant "SpringBoot\n后端" as B
database "MySQL" as D

== 获取验证码 ==

S -> F : 填写注册信息，点击获取验证码
activate F

F -> B : GET /user/send-code?email=xxx&type=register
activate B

B -> B : 生成 6 位随机验证码

B -> D : INSERT INTO sys_email_code\n(email, code, type, expire_time)
activate D
D --> B : OK
deactivate D

note right of B
    开发阶段通过 console
    输出验证码，生产环境
    对接邮件服务
end note

B --> F : {message: "验证码已发送"}
deactivate B

F --> S : 提示"验证码已发送至邮箱"

|||

== 提交注册 ==

S -> F : 输入验证码，点击注册
F -> B : POST /user/register\n{username, email, code, password}
activate B

B -> D : 校验账号唯一性\n+ 验证码有效性
activate D
D --> B : 校验结果
deactivate D

alt 校验通过
    B -> B : MD5 加密密码\nrole_id = 3 (学生)

    B -> D : INSERT INTO sys_user\n(username, password, email, role_id)
    activate D
    D --> B : OK
    deactivate D

    B -> D : UPDATE sys_email_code\nSET is_used = 1
    activate D
    D --> B : OK
    deactivate D

    B --> F : 200 OK\n{message: "注册成功"}
    deactivate B
    F --> S : 跳转登录页

else 校验失败
    B --> F : 400 Bad Request\n{message: "验证码错误/账号已存在"}
    deactivate B
    F --> S : 显示错误提示
end

deactivate F

@enduml
