/*
 * ============================================================
 * KG 智能导学系统 — ER 图 (传统 Chen 记法 · 黑白)
 * 矩形=实体  菱形=关系  椭圆=属性
 * ============================================================
 */
digraph ER_Chen {
    rankdir=LR;
    splines=polyline;
    fontname="Times-Roman";
    fontsize=14;
    label="KG 智能导学系统 — 实体关系图 (Chen Notation)";
    labelloc=t;
    bgcolor="white";

    node [fontname="Times-Roman", fontsize=10, color=black, fontcolor=black];
    edge [fontname="Times-Roman", fontsize=8, color=black, fontcolor=black];

    /* ====== 实体 (矩形) ====== */
    node [shape=box, style=solid, color=black, penwidth=1.5, fillcolor=none];

    sys_role     [label="sys_role\n系统角色"];
    sys_user     [label="sys_user\n系统用户"];
    sys_email    [label="sys_email_code\n邮箱验证码"];
    course       [label="course\n课程"];
    knode        [label="knowledge_node\n知识点节点"];
    kedge        [label="knowledge_edge\n知识点依赖边"];
    question     [label="question\n习题库"];
    exam         [label="exam\n测评定义"];
    exam_q       [label="exam_question\n测评题目关联"];
    exam_record  [label="exam_record\n测评记录"];
    study_record [label="study_record\n学习记录"];
    study_path   [label="study_path\n学习路径"];
    path_detail  [label="path_detail\n路径详情"];
    wrong_q      [label="wrong_question\n错题本"];
    theme        [label="cross_subject_theme\n跨学科主题"];
    theme_node   [label="cross_theme_node\n主题-知识点关联"];
    sys_notice   [label="sys_notice\n系统公告"];
    sys_log      [label="sys_oper_log\n操作日志"];
    ai_log       [label="ai_call_log\nAI调用日志"];

    /* ====== 关系 (菱形) ====== */
    node [shape=diamond, style=solid, color=black, penwidth=1.5, fillcolor=none];

    R_has_user   [label="拥有"];       R_teaches  [label="授课"];
    R_contains   [label="包含"];       R_prereq   [label="前置"];
    R_leads_to   [label="后继"];       R_belongs  [label="属于"];
    R_creates    [label="创建"];       R_exam_course [label="关联"];
    R_links      [label="关联题目"];   R_takes    [label="参加"];
    R_studies    [label="学习"];       R_generates [label="生成"];
    R_details    [label="包含节点"];   R_wrong    [label="做错"];
    R_publishes  [label="发布"];       R_theme_node [label="关联"];
    R_notifies   [label="发布"];       R_operates [label="操作"];
    R_calls      [label="调用"];

    /* ====== 属性 (椭圆) ====== */
    node [shape=ellipse, style=solid, color=black, penwidth=0.8, fillcolor=none, fontsize=8];

    A_role_id    [label="id {PK}"];     A_role_code [label="role_code"];
    A_user_id    [label="id {PK}"];     A_username  [label="username"];
    A_email      [label="email"];       A_password  [label="password"];
    A_course_id  [label="id {PK}"];     A_course_name [label="course_name"];
    A_node_id    [label="id {PK}"];     A_node_name  [label="name"];
    A_q_id       [label="id {PK}"];     A_q_content  [label="content"];
    A_exam_id    [label="id {PK}"];     A_exam_name  [label="exam_name"];
    A_sr_id      [label="id {PK}"];     A_mastery    [label="mastery_level"];
    A_sp_id      [label="id {PK}"];     A_sp_name    [label="path_name"];
    A_wq_id      [label="id {PK}"];     A_theme_id   [label="id {PK}"];
    A_notice_id  [label="id {PK}"];

    /* ====== 属性连线 ====== */
    edge [color=black, penwidth=0.8, arrowhead=none];
    sys_role -> A_role_id; sys_role -> A_role_code;
    sys_user -> A_user_id; sys_user -> A_username; sys_user -> A_email; sys_user -> A_password;
    course -> A_course_id; course -> A_course_name;
    knode -> A_node_id; knode -> A_node_name;
    question -> A_q_id; question -> A_q_content;
    exam -> A_exam_id; exam -> A_exam_name;
    study_record -> A_sr_id; study_record -> A_mastery;
    study_path -> A_sp_id; study_path -> A_sp_name;
    wrong_q -> A_wq_id; theme -> A_theme_id; sys_notice -> A_notice_id;

    /* ====== 关系连线 — 强关联 ====== */
    edge [color=black, penwidth=1.2, arrowhead=none, fontsize=7, style=solid];

    sys_role -> R_has_user [label="1"];     R_has_user -> sys_user [label="N"];
    sys_user -> R_teaches [label="1"];      R_teaches -> course [label="N"];
    course -> R_contains [label="1"];        R_contains -> knode [label="N"];
    knode -> R_prereq [label="N"];           R_prereq -> kedge [label="1"];
    kedge -> R_leads_to [label="1"];         R_leads_to -> knode [label="N"];
    knode -> R_belongs [label="1"];          R_belongs -> question [label="N"];
    sys_user -> R_creates [label="1"];       R_creates -> exam [label="N"];
    course -> R_exam_course [label="1"];     R_exam_course -> exam [label="N"];
    exam -> R_links [label="N"];             R_links -> exam_q [label="1"];
    exam_q -> question [label="N"];          /* weak link from exam_q to question visualized here */
    sys_user -> R_takes [label="1"];         R_takes -> exam_record [label="N"];
    sys_user -> R_studies [label="1"];       R_studies -> study_record [label="N"];
    sys_user -> R_generates [label="1"];     R_generates -> study_path [label="N"];
    study_path -> R_details [label="1"];     R_details -> path_detail [label="N"];
    sys_user -> R_wrong [label="1"];         R_wrong -> wrong_q [label="N"];
    sys_user -> R_publishes [label="1"];     R_publishes -> theme [label="N"];
    theme -> R_theme_node [label="N"];       R_theme_node -> theme_node [label="1"];
    sys_user -> R_notifies [label="1"];      R_notifies -> sys_notice [label="N"];

    /* ====== 弱关联 (虚线, 无FK约束) ====== */
    edge [color=black, penwidth=0.8, style=dashed];
    sys_user -> R_operates [label="0..1"];
    R_operates -> sys_log [label="N"];
    R_operates [style="dashed,solid"];
    sys_user -> R_calls [label="0..1"];
    R_calls -> ai_log [label="N"];
    R_calls [style="dashed,solid"];

    /* ====== 图例 ====== */
    subgraph cluster_legend {
        label="图例";
        fontsize=10;
        style=solid;
        color=black;
        bgcolor="white";
        node [shape=plaintext, fontsize=8];
        l1 [label="□ 实体    ◇ 关系    ○ 属性    ── 强关联    ╌╌ 弱关联    1/N 基数    {PK} 主键"];
    }
}
