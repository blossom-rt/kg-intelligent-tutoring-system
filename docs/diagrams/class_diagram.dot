/*
 * KG 智能导学系统 — 类图 (UML · 黑白 · 竖版)
 * ▷=泛化  →=关联  ⇢=依赖
 * 强制竖向：Controller → Service → Mapper → POJO 自上而下
 */
digraph UML_Class {
    rankdir=TB;
    splines=polyline;
    fontname="Times-Roman";
    fontsize=14;
    label="KG 智能导学系统 — 类图\n▷ 泛化    → 关联    ⇢ 依赖";
    bgcolor="white";
    nodesep=0.3;
    ranksep=0.5;

    node [fontname="Times-Roman", fontsize=8, color=black, fontcolor=black, shape=box, style=solid, width=1.2, height=0.3];
    edge [fontname="Times-Roman", fontsize=6, color=black, fontcolor=black];

    /* ====== 第1层：Controller ====== */
    { rank=same;
        AuthC [label="AuthController"]; StuC [label="StudentController"];
        StuGC [label="StudentGraphController"]; StuPC [label="StudentPathController"];
        StuPrC [label="StudentPracticeController"]; StuEC [label="StudentExamController"];
        StuWC [label="StudentWrongController"]; StuAC [label="StudentAnalysisController"];
        TeachC [label="TeacherController"]; TeachEC [label="TeacherExamController"];
        TeachAC [label="TeacherAnalysisController"]; AdminC [label="AdminController"];
        CourseC [label="CourseController"]; NodeC [label="NodeController"];
        QuesC [label="QuestionController"]; NoticeC [label="NoticeController"];
        ThemeC [label="ThemeController"];
    }

    /* ====== 第2层：Service Interface ====== */
    { rank=same;
        UserS [label="«interface»\nSysUserService", style=dashed];
        CourseS [label="«interface»\nCourseService", style=dashed];
        NodeS [label="«interface»\nKnowledgeNodeService", style=dashed];
        EdgeS [label="«interface»\nKnowledgeEdgeService", style=dashed];
        QuesS [label="«interface»\nQuestionService", style=dashed];
        ExamS [label="«interface»\nExamService", style=dashed];
        ExamRS [label="«interface»\nExamRecordService", style=dashed];
        PathS [label="«interface»\nStudyPathService", style=dashed];
        StudyRS [label="«interface»\nStudyRecordService", style=dashed];
        WrongS [label="«interface»\nWrongQuestionService", style=dashed];
        ThemeS [label="«interface»\nCrossSubjectThemeService", style=dashed];
        AnalyS [label="«interface»\nAnalysisService", style=dashed];
        NoticeS [label="«interface»\nSysNoticeService", style=dashed];
        RoleS [label="«interface»\nSysRoleService", style=dashed];
        LogS [label="«interface»\nLogService", style=dashed];
    }

    /* ====== 第3层：ServiceImpl ====== */
    { rank=same;
        UserSI [label="SysUserServiceImpl"]; CourseSI [label="CourseServiceImpl"];
        NodeSI [label="KnowledgeNodeServiceImpl"]; EdgeSI [label="KnowledgeEdgeServiceImpl"];
        QuesSI [label="QuestionServiceImpl"]; ExamSI [label="ExamServiceImpl"];
        ExamRSI [label="ExamRecordServiceImpl"]; PathSI [label="StudyPathServiceImpl"];
        StudyRSI [label="StudyRecordServiceImpl"]; WrongSI [label="WrongQuestionServiceImpl"];
        ThemeSI [label="CrossSubjectThemeServiceImpl"]; AnalySI [label="AnalysisServiceImpl"];
        NoticeSI [label="SysNoticeServiceImpl"]; RoleSI [label="SysRoleServiceImpl"];
        LogSI [label="LogServiceImpl"];
    }

    /* ====== 第4层：Mapper ====== */
    { rank=same;
        BaseM [label="«abstract»\nBaseMapper", style="solid,dashed"];
        UserM [label="SysUserMapper"]; RoleM [label="SysRoleMapper"];
        EmailM [label="SysEmailCodeMapper"]; CourseM [label="CourseMapper"];
        NodeM [label="KnowledgeNodeMapper"]; EdgeM [label="KnowledgeEdgeMapper"];
        QuesM [label="QuestionMapper"]; ExamM [label="ExamMapper"];
        ExamRM [label="ExamRecordMapper"]; StudyRM [label="StudyRecordMapper"];
        PathM [label="StudyPathMapper"]; WrongM [label="WrongQuestionMapper"];
        ThemeM [label="CrossSubjectThemeMapper"]; NoticeM [label="SysNoticeMapper"];
        OperM [label="SysOperLogMapper"]; AiM [label="AiCallLogMapper"];
    }

    /* ====== 第5层：POJO ====== */
    { rank=same;
        SysUser [label="SysUser"]; SysRole [label="SysRole"];
        SysEmail [label="SysEmailCode"]; Course [label="Course"];
        KNode [label="KnowledgeNode"]; KEdge [label="KnowledgeEdge"];
        Question [label="Question"]; Exam [label="Exam"];
        ExamR [label="ExamRecord"]; StudyR [label="StudyRecord"];
        StudyP [label="StudyPath"]; WrongQ [label="WrongQuestion"];
        CrossT [label="CrossSubjectTheme"]; SysNot [label="SysNotice"];
        SysOpL [label="SysOperLog"]; AiLog [label="AiCallLog"];
    }

    /* ====== 泛化: ServiceImpl ▷ Service ====== */
    edge [arrowhead=onormal, style=solid, penwidth=1.2];
    UserSI -> UserS; CourseSI -> CourseS; NodeSI -> NodeS; EdgeSI -> EdgeS;
    QuesSI -> QuesS; ExamSI -> ExamS; ExamRSI -> ExamRS; PathSI -> PathS;
    StudyRSI -> StudyRS; WrongSI -> WrongS; ThemeSI -> ThemeS; AnalySI -> AnalyS;
    NoticeSI -> NoticeS; RoleSI -> RoleS; LogSI -> LogS;

    /* ====== 泛化: Mapper ▷ BaseMapper ====== */
    UserM -> BaseM; RoleM -> BaseM; EmailM -> BaseM; CourseM -> BaseM;
    NodeM -> BaseM; EdgeM -> BaseM; QuesM -> BaseM; ExamM -> BaseM;
    ExamRM -> BaseM; StudyRM -> BaseM; PathM -> BaseM; WrongM -> BaseM;
    ThemeM -> BaseM; NoticeM -> BaseM; OperM -> BaseM; AiM -> BaseM;

    /* ====== 关联: ServiceImpl → Mapper ====== */
    edge [arrowhead=vee, style=solid, penwidth=0.8];
    UserSI -> UserM; UserSI -> RoleM; UserSI -> EmailM;
    CourseSI -> CourseM; NodeSI -> NodeM; EdgeSI -> EdgeM;
    QuesSI -> QuesM; ExamSI -> ExamM; ExamRSI -> ExamRM;
    PathSI -> PathM; PathSI -> NodeM; StudyRSI -> StudyRM;
    WrongSI -> WrongM; ThemeSI -> ThemeM; AnalySI -> StudyRM;
    NoticeSI -> NoticeM; RoleSI -> RoleM;
    LogSI -> OperM; LogSI -> AiM;

    /* ====== 关联: Controller → Service ====== */
    AuthC -> UserS; StuC -> UserS; StuC -> NodeS; StuGC -> NodeS;
    StuGC -> PathS; StuPC -> PathS; StuPrC -> QuesS; StuPrC -> StudyRS;
    StuEC -> ExamS; StuEC -> ExamRS; StuWC -> WrongS; StuAC -> AnalyS;
    TeachC -> UserS; TeachC -> CourseS; TeachC -> NodeS; TeachEC -> ExamS;
    TeachAC -> AnalyS; AdminC -> UserS; AdminC -> RoleS; AdminC -> LogS;
    CourseC -> CourseS; NodeC -> NodeS; QuesC -> QuesS;
    NoticeC -> NoticeS; ThemeC -> ThemeS;

    /* ====== 依赖: Controller ⇢ POJO (虚线) ====== */
    edge [arrowhead=vee, style=dashed, penwidth=0.6, color="#555555"];
    AuthC -> SysUser; StuGC -> KNode; StuPrC -> Question;
    StuEC -> Exam; StuEC -> ExamR; StuWC -> WrongQ; StuPC -> StudyP;
    StuAC -> StudyR; TeachEC -> Exam; AdminC -> SysUser;
    CourseC -> Course; NodeC -> KNode; QuesC -> Question;
    NoticeC -> SysNot; ThemeC -> CrossT;

    /* ====== 图例 ====== */
    { rank=sink;
        legend [label="▷ 泛化(Generalization)    → 关联(Association)    ⇢ 依赖(Dependency)", shape=plaintext, fontsize=10];
    }
}
