AnalysisServiceImpl -up-|> AnalysisService
SysNoticeServiceImpl -up-|> SysNoticeService
SysRoleServiceImpl -up-|> SysRoleService
LogServiceImpl -up-|> LogService

' ── 泛化 (Mapper继承) ──
SysUserMapper -up-|> BaseMapper
SysRoleMapper -up-|> BaseMapper
CourseMapper -up-|> BaseMapper
KnowledgeNodeMapper -up-|> BaseMapper
KnowledgeEdgeMapper -up-|> BaseMapper
