@startuml kg_class
' ============================================================
' KG 智能导学系统 — 类图 (UML · 黑白)
' △ 泛化(generalization)  — 关联(association)  ╌╌ 依赖(dependency)
' ============================================================
skinparam backgroundColor white
skinparam defaultFontName "Times-Roman"
skinparam class {
    BackgroundColor white
    BorderColor black
    FontSize 11
}
skinparam arrow {
    Color black
}
skinparam note {
    BackgroundColor white
    BorderColor black
}

' ==============================
' POJO — 数据模型
' ==============================

class SysUser {
    + id : Integer
    + username : String
    + realName : String
    + email : String
    + password : String
    + roleId : Integer
    + status : Integer
}
class SysRole {
    + id : Integer
    + roleCode : String
    + roleName : String
}
class SysEmailCode {
    + id : Integer
    + email : String
    + code : String
    + type : String
    + expireTime : LocalDateTime
}
class Course {
    + id : Integer
    + subject : String
    + courseName : String
    + teacherId : Integer
}
class KnowledgeNode {
    + id : Integer
    + courseId : Integer
    + name : String
    + difficulty : Integer
}
class KnowledgeEdge {
    + id : Integer
    + fromNodeId : Integer
    + toNodeId : Integer
    + relationType : String
}
class Question {
    + id : Integer
    + nodeId : Integer
    + content : String
    + options : String
    + answer : String
    + difficulty : Integer
    + questionType : String
}
class Exam {
    + id : Integer
    + examName : String
    + courseId : Integer
    + creatorId : Integer
    + totalScore : Integer
}
class ExamQuestion {
    + id : Integer
    + examId : Integer
    + questionId : Integer
}
class ExamRecord {
    + id : Integer
    + userId : Integer
    + examId : Integer
    + userScore : BigDecimal
    + aiReport : String
}
class StudyRecord {
    + id : Integer
    + userId : Integer
    + nodeId : Integer
    + masteryLevel : Integer
    + correctRate : BigDecimal
}
class StudyPath {
    + id : Integer
    + userId : Integer
    + targetNodeId : Integer
    + pathName : String
    + status : Integer
}
class PathDetail {
    + id : Integer
    + pathId : Integer
    + nodeId : Integer
    + sortOrder : Integer
}
class WrongQuestion {
    + id : Integer
    + userId : Integer
    + questionId : Integer
    + wrongCount : Integer
    + aiExplain : String
}
class CrossSubjectTheme {
    + id : Integer
    + themeName : String
    + publisherId : Integer
    + status : Integer
}
class CrossThemeNode {
    + id : Integer
    + themeId : Integer
    + nodeId : Integer
}
class SysNotice {
    + id : Integer
    + title : String
    + content : String
    + publisherId : Integer
}
class SysOperLog {
    + id : Integer
    + userId : Integer
    + module : String
    + operation : String
}
class AiCallLog {
    + id : Integer
    + userId : Integer
    + scene : String
    + prompt : String
    + result : String
}

' ==============================
' Service 接口 & 实现
' ==============================

interface SysUserService {
    + login(LoginDTO) : LoginVO
    + register(RegisterDTO) : void
    + sendEmailCode(email, type) : void
    + resetPassword(ResetPasswordDTO) : void
    + getCurrentUserInfo() : LoginVO
    + listUsers(keyword, roleId) : List
}
class SysUserServiceImpl  {
}

interface CourseService {
    + list(subject) : List
    + getById(id) : Course
    + save(Course) : void
    + update(Course) : void
    + delete(id) : void
}
class CourseServiceImpl  {
}

interface KnowledgeNodeService {
    + list(courseId, name) : List
    + getById(id) : KnowledgeNode
    + save(KnowledgeNode) : void
    + update(KnowledgeNode) : void
    + delete(id) : void
}
class KnowledgeNodeServiceImpl  {
}

interface KnowledgeEdgeService {
    + listAll() : List
    + save(KnowledgeEdge) : void
    + delete(id) : void
}
class KnowledgeEdgeServiceImpl  {
}

interface QuestionService {
    + list(nodeId, difficulty) : List
    + getById(id) : Question
    + save(Question) : void
    + update(Question) : void
    + delete(id) : void
}
class QuestionServiceImpl  {
}

interface ExamService {
    + listForTeacher(courseId) : List
    + listForStudent(userId) : List
    + createExam(name, courseId, questionIds, score) : void
    + getPaper(examId) : Map
    + deleteExam(id) : void
}
class ExamServiceImpl  {
}

interface ExamRecordService {
    + submitExam(userId, dto) : void
    + listByUser(userId) : List
    + getById(id) : Map
}
class ExamRecordServiceImpl  {
}

interface StudyPathService {
    + generatePath(userId, targetNodeId) : void
    + listByUser(userId) : List
    + getById(id) : StudyPath
    + deletePath(pathId, userId) : void
}
class StudyPathServiceImpl  {
}

interface StudyRecordService {
    + getByUserAndNode(userId, nodeId) : StudyRecord
    + updateRecord(userId, nodeId, mastery, rate, minutes) : void
}
class StudyRecordServiceImpl  {
}

interface WrongQuestionService {
    + listByUser(userId) : List
    + remove(id, userId) : void
}
class WrongQuestionServiceImpl  {
}

interface CrossSubjectThemeService {
    + list(difficulty, status) : List
    + getById(id) : CrossSubjectTheme
    + save(CrossSubjectTheme) : void
    + update(CrossSubjectTheme) : void
    + toggleStatus(id) : void
}
class CrossSubjectThemeServiceImpl  {
}

interface AnalysisService {
    + personalAnalysis(userId) : Map
    + weakAnalysis(userId) : List
    + classAnalysis(courseId) : Map
}
class AnalysisServiceImpl  {
}

interface SysNoticeService {
    + listPublic() : List
    + list() : List
    + save(SysNotice) : void
    + delete(id) : void
}
class SysNoticeServiceImpl  {
}

interface SysRoleService {
    + listAll() : List
}
class SysRoleServiceImpl  {
}

interface LogService {
    + listOperLog(module) : List
    + listAiLog(scene) : List
}
class LogServiceImpl  {
}

' ==============================
' Mapper (MyBatis-Plus)
' ==============================

abstract class "BaseMapper<T>" {
    {abstract} + selectList(wrapper) : List
    {abstract} + selectById(id) : T
    {abstract} + insert(entity) : int
    {abstract} + updateById(entity) : int
    {abstract} + deleteById(id) : int
}

class SysUserMapper  {}
class SysRoleMapper  {}
class SysEmailCodeMapper  {}
class CourseMapper  {}
class KnowledgeNodeMapper  {}
class KnowledgeEdgeMapper  {}
class QuestionMapper  {}
class ExamMapper  {}
class ExamQuestionMapper  {}
class ExamRecordMapper  {}
class StudyRecordMapper  {}
class StudyPathMapper  {}
class PathDetailMapper  {}
class WrongQuestionMapper  {}
class CrossSubjectThemeMapper  {}
class CrossThemeNodeMapper  {}
class SysNoticeMapper  {}
class SysOperLogMapper  {}
class AiCallLogMapper  {}

' ==============================
' Controller
' ==============================

class AuthController  {
    + POST /login
    + POST /register
    + POST /send-code
    + POST /reset-password
}
class StudentController  {
    + GET /dashboard
    + GET /knowledge-nodes
}
class StudentGraphController  {
    + GET /graph
    + POST /generate-path
}
class StudentPathController  {
    + POST /generate
    + GET /list
    + GET /{id}
    + DELETE /{id}
}
class StudentPracticeController  {
    + GET /questions
    + POST /submit
}
class StudentExamController  {
    + GET /exams
    + GET /exam-paper/{id}
    + POST /exam/submit
}
class StudentWrongController  {
    + GET /wrong-questions
    + DELETE /wrong-questions/{id}
}
class StudentAnalysisController  {
    + GET /personal
    + GET /weak
}
class StudentAiController  {
    + POST /wrong-explain
    + POST /exam-report
}
class TeacherController  {
    + GET /dashboard
    + GET /courses
    + POST /courses
}
class TeacherExamController  {
    + GET /
    + POST /
    + DELETE /{id}
}
class TeacherAnalysisController  {
    + GET /class
}
class AdminController  {
    + GET /users
    + POST /users
    + PUT /users/{id}
    + DELETE /users/{id}
    + GET /roles
    + GET /oper-logs
    + GET /ai-logs
}
class CourseController  {
    + GET /
    + POST /
    + PUT /{id}
    + DELETE /{id}
}
class NodeController  {
    + GET /
    + POST /
    + PUT /{id}
    + DELETE /{id}
}
class QuestionController  {
    + GET /
    + POST /
    + PUT /{id}
    + DELETE /{id}
}
class NoticeController  {
    + GET /
    + POST /
    + DELETE /{id}
}
class ThemeController  {
    + GET /
    + POST /
    + PUT /{id}
    + DELETE /{id}
}

' ============================================================
'  关 系
' ============================================================

